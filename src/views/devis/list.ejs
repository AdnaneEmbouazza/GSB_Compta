<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Devis</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="/dashboard"><img src="/img/gsb-logo.webp" alt="Logo GSB" class="logo-nav"></a>
            </div>
            <div class="nav-links">
                <a href="/articles">Articles</a>
                <a href="/contacts">Contacts</a>
                <a href="/factures">Factures</a>
                <a href="/devis">Devis</a>
                <a href="/logout">Déconnexion</a>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <div class="page-header">
            <h1><svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="11" x2="12" y2="17"></line><line x1="9" y1="14" x2="15" y2="14"></line></svg> Devis</h1>
            <a href="/devis/new" class="btn btn-primary">+ Nouveau devis</a>
        </div>

        <% if (devis && devis.length > 0) { %>
            <table class="table">
                <thead>
                    <tr>
                        <th>Numéro</th>
                        <th>Contact</th>
                        <th>Date</th>
                        <th>Montant TTC (€)</th>
                        <th>État</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% devis.forEach(d => { %>
                        <tr>
                            <td><strong><%= d.numero_devis %></strong></td>
                            <td><%= d.nom_contact %></td>
                            <td><%= new Date(d.date_devis).toLocaleDateString('fr-FR') %></td>
                            <td><%= d.montant_ttc.toFixed(2) %></td>
                            <td><span class="badge"><%= d.etat_devis %></span></td>
                            <td>
                                <a href="/devis/<%= d.id_devis %>" class="btn btn-sm btn-secondary">Voir</a>
                                <button class="btn btn-sm btn-danger" onclick="deleteItem(<%= d.id_devis %>, 'Devis <%= d.numero_devis %>', '/devis', '/devis')">Supprimer</button>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div class="alert alert-info">
                Aucun devis pour le moment.
            </div>
        <% } %>
    </div>

    <footer class="footer">
        <p>&copy; 2026 - Gestion Comptabilité Simple</p>
    </footer>
    <script src="/js/delete.js"></script>
</body>
</html>
