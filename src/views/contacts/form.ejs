<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="/dashboard"><svg class="icon-sm" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2m0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3m0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22"/></svg> </a>
            </div>
            <div class="nav-links">
                <a href="/articles">Articles</a>
                <a href="/categories">Catégories</a>
                <a href="/contacts">Contacts</a>
                <a href="/factures">Factures</a>
                <a href="/devis">Devis</a>
                <a href="/logout">Déconnexion</a>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <h1><%= title %></h1>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger">
                <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg> <%= error %>
            </div>
        <% } %>

        <form id="contactForm" class="form">
            <div class="form-row">
                <div class="form-group">
                    <label for="nom_contact">Nom *</label>
                    <input type="text" id="nom_contact" name="nom_contact" value="<%= contact ? contact.nom_contact : '' %>" required>
                </div>

                <div class="form-group">
                    <label for="type_contact">Type *</label>
                    <select id="type_contact" name="type_contact" required>
                        <option value="">Sélectionner...</option>
                        <option value="client" <%= contact && contact.type_contact === 'client' ? 'selected' : '' %>>Client</option>
                        <option value="fournisseur" <%= contact && contact.type_contact === 'fournisseur' ? 'selected' : '' %>>Fournisseur</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="email_contact">Email</label>
                    <input type="email" id="email_contact" name="email_contact" value="<%= contact ? (contact.email_contact || '') : '' %>">
                </div>

                <div class="form-group">
                    <label for="telephone">Téléphone</label>
                    <input type="tel" id="telephone" name="telephone" value="<%= contact ? (contact.telephone || '') : '' %>">
                </div>
            </div>

            <div class="form-group">
                <label for="adresse">Adresse</label>
                <input type="text" id="adresse" name="adresse" value="<%= contact ? (contact.adresse || '') : '' %>">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="code_postal">Code postal</label>
                    <input type="text" id="code_postal" name="code_postal" value="<%= contact ? (contact.code_postal || '') : '' %>">
                </div>

                <div class="form-group">
                    <label for="ville">Ville</label>
                    <input type="text" id="ville" name="ville" value="<%= contact ? (contact.ville || '') : '' %>">
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a href="/contacts" class="btn btn-secondary">Annuler</a>
            </div>
        </form>

        <script>
            const form = document.getElementById('contactForm');
            const isEditing = '<%= contact ? "yes" : "" %>';
            const contactId = '<%= contact ? contact.id_contact : "" %>';

            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const data = {
                    nom_contact: document.getElementById('nom_contact').value,
                    type_contact: document.getElementById('type_contact').value,
                    email_contact: document.getElementById('email_contact').value,
                    telephone: document.getElementById('telephone').value,
                    adresse: document.getElementById('adresse').value,
                    code_postal: document.getElementById('code_postal').value,
                    ville: document.getElementById('ville').value
                };

                try {
                    const method = isEditing ? 'PUT' : 'POST';
                    const url = isEditing ? `/contacts/${contactId}` : '/contacts';

                    const response = await fetch(url, {
                        method: method,
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        window.location.href = '/contacts';
                    } else {
                        const errorData = await response.json();
                        alert('Erreur: ' + (errorData.error || 'Une erreur est survenue'));
                    }
                } catch (error) {
                    console.error('Erreur lors de la requête:', error);
                    alert('Erreur lors de l\'envoi du formulaire');
                }
            });
        </script>
    </div>

    <footer class="footer">
        <p>&copy; 2026 - GSB COMPTABILITE</p>
    </footer>
</body>
</html>
