<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="/dashboard"><img src="/img/gsb-logo.webp" alt="Logo GSB" class="logo-nav"></a>
            </div>
            <div class="nav-links">
                <a href="/articles">Articles</a>
                <a href="/contacts">Contacts</a>
                <a href="/factures">Factures</a>
                <a href="/devis">Devis</a>
                <a href="/logout">Déconnexion</a>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <div class="page-header">
            <h1><%= title %></h1>
            <a href="/factures" class="btn btn-secondary">← Retour</a>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
        <% } %>

        <!-- Ligne 1: Informations et Statut côte à côte -->
        <div class="document-layout">
            <!-- Informations principales -->
            <div class="document-section">
                <h2>Informations</h2>
                <div class="info-grid">
                    <div>
                        <strong>Numéro :</strong> <%= facture.numero_facture %>
                    </div>
                    <div>
                        <strong>Contact :</strong> <%= facture.nom_contact %> 
                        <% if (facture.email_contact) { %>
                            (<%= facture.email_contact %>)
                        <% } %>
                    </div>
                    <div>
                        <strong>Date :</strong> <%= new Date(facture.date_facture).toLocaleDateString('fr-FR') %>
                    </div>
                    <div>
                        <strong>Échéance :</strong> <%= facture.date_echeance ? new Date(facture.date_echeance).toLocaleDateString('fr-FR') : '-' %>
                    </div>
                </div>
            </div>

            <!-- Statut et paiement -->
            <div class="document-section">
                <h2>Statut & Paiement</h2>
                <form id="statusForm" style="display: flex; flex-direction: column; gap: 15px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="etat_facture">État</label>
                        <select id="etat_facture" name="etat_facture">
                            <option value="brouillon" <%= facture.etat_facture === 'brouillon' ? 'selected' : '' %>>Brouillon</option>
                            <option value="envoyée" <%= facture.etat_facture === 'envoyée' ? 'selected' : '' %>>Envoyée</option>
                            <option value="payée" <%= facture.etat_facture === 'payée' ? 'selected' : '' %>>Payée</option>
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="est_payee">
                            <input type="checkbox" id="est_payee" name="est_payee" <%= facture.est_payee ? 'checked' : '' %>>
                            Marquée comme payée
                        </label>
                    </div>

                    <div class="form-group" style="margin-bottom: 0;">
                        <label for="date_paiement">Date de paiement</label>
                        <input type="date" id="date_paiement" name="date_paiement" value="<%= facture.date_paiement || '' %>">
                    </div>

                    <button type="submit" class="btn btn-sm btn-primary" style="align-self: flex-start;">Mettre à jour</button>
                </form>
            </div>
        </div>

        <!-- Ligne 2: Articles sur toute la largeur -->
        <div class="document-section document-layout full">
            <h2>Articles</h2>
            
            <% if (lignes && lignes.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>Quantité</th>
                            <th>Prix unitaire (€)</th>
                            <th>Montant (€)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% lignes.forEach(ligne => { %>
                            <tr>
                                <td><%= ligne.description || '-' %></td>
                                <td><%= ligne.quantite %></td>
                                <td><%= ligne.prix_unitaire.toFixed(2) %></td>
                                <td><%= ligne.montant.toFixed(2) %></td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="deleteLigneFacture(<%= facture.id_facture %>, <%= ligne.id_ligne %>)">Supprimer</button>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>Aucun article</p>
            <% } %>

            <!-- Formulaire ajout ligne -->
            <h3 style="margin-top: 2rem; margin-bottom: 1rem;">Ajouter une ligne</h3>
            <form method="POST" action="/factures/<%= facture.id_facture %>/lignes" class="form-row" style="background: transparent; padding: 0; margin-bottom: 0; box-shadow: none;" id="addLineForm">
                <div class="form-group">
                    <label for="id_article">Article</label>
                    <select id="id_article" name="id_article" onchange="updateStock(this)">
                        <option value="">Sélectionner...</option>
                        <% articles.forEach(article => { %>
                            <option value="<%= article.id_article %>" data-stock="<%= article.quantite_stock %>" data-name="<%= article.nom_article %>">
                                <%= article.nom_article %> - <%= article.prix_unitaire.toFixed(2) %>€
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <input type="text" id="description" name="description">
                </div>

                <div class="form-group">
                    <label for="quantite">Quantité * <span id="stockInfo" style="color: #666; font-size: 0.9rem;"></span></label>
                    <input type="number" id="quantite" name="quantite" value="1" min="1" required>
                </div>

                <button type="submit" class="btn btn-primary" style="align-self: flex-end; margin-top: auto;">Ajouter</button>
            </form>

            <script>
            const articlesData = {
                <% articles.forEach((article, idx) => { %>
                    '<%= article.id_article %>': { stock: <%= article.quantite_stock %>, name: '<%= article.nom_article %>' }<%= idx < articles.length - 1 ? ',' : '' %>
                <% }); %>
            };

            function updateStock(select) {
                const selectedId = select.value;
                const quantiteInput = document.getElementById('quantite');
                const stockInfo = document.getElementById('stockInfo');
                
                if (selectedId && articlesData[selectedId]) {
                    const stock = articlesData[selectedId].stock;
                    quantiteInput.max = Math.max(0, stock);
                    quantiteInput.value = 1;
                    
                    if (stock <= 0) {
                        stockInfo.textContent = '(Stock insuffisant)';
                        stockInfo.style.color = '#e74c3c';
                        quantiteInput.disabled = true;
                    } else {
                        stockInfo.textContent = `(Disponible: ${stock})`;
                        stockInfo.style.color = '#666';
                        quantiteInput.disabled = false;
                    }
                } else {
                    quantiteInput.max = '';
                    quantiteInput.value = 1;
                    quantiteInput.disabled = false;
                    stockInfo.textContent = '';
                }
            }

            // Validation à la soumission du formulaire
            document.getElementById('addLineForm').addEventListener('submit', function(e) {
                const selectedId = document.getElementById('id_article').value;
                const quantite = parseInt(document.getElementById('quantite').value);
                
                if (!selectedId) {
                    e.preventDefault();
                    alert('Veuillez sélectionner un article');
                    return;
                }

                if (articlesData[selectedId]) {
                    const stock = articlesData[selectedId].stock;
                    if (quantite > stock) {
                        e.preventDefault();
                        alert(`La quantité saisis dépasse le stock disponible (${stock} disponibles).`);
                        return;
                    }
                    if (stock <= 0) {
                        e.preventDefault();
                        alert('Cet article n\'a pas de stock disponible.');
                        return;
                    }
                }
            });
            </script>
        </div>

        <!-- Ligne 3: Totaux et Notes côte à côte -->
        <div class="document-layout">
            <!-- Totaux -->
            <div class="card total-card">
                <div class="total-line">
                    <span>Sous-total HT :</span>
                    <strong><%= facture.montant_ht.toFixed(2) %>€</strong>
                </div>
                <div class="total-line">
                    <span>TVA (20%) :</span>
                    <strong><%= facture.montant_tva.toFixed(2) %>€</strong>
                </div>
                <div class="total-line total-highlight">
                    <span>Total TTC :</span>
                    <strong><%= facture.montant_ttc.toFixed(2) %>€</strong>
                </div>
            </div>

            <!-- Notes -->
            <div class="document-section">
                <h2>Notes</h2>
                <% if (facture.notes) { %>
                    <p><%= facture.notes %></p>
                <% } else { %>
                    <p style="color: #999; font-style: italic;">Aucune note</p>
                <% } %>
            </div>
        </div>

    </div>

    <footer class="footer">
        <p>&copy; 2026 - Gestion Comptabilité Simple | Express.js + SQLite</p>
    </footer>

    <script>
        // Gestion du formulaire de statut avec fetch PUT
        const statusForm = document.getElementById('statusForm');
        const factureId = '<%= facture.id_facture %>';

        statusForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const data = {
                etat_facture: document.getElementById('etat_facture').value,
                est_payee: document.getElementById('est_payee').checked,
                date_paiement: document.getElementById('date_paiement').value || null
            };

            try {
                const response = await fetch(`/factures/${factureId}/status`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    // Recharge la page pour afficher les changements
                    window.location.reload();
                } else {
                    const errorData = await response.json();
                    alert('Erreur: ' + (errorData.error || 'Une erreur est survenue'));
                }
            } catch (error) {
                console.error('Erreur lors de la requête:', error);
                alert('Erreur lors de la mise à jour du statut');
            }
        });

        // Fonction pour supprimer une ligne avec fetch DELETE
        async function deleteLigneFacture(factureId, idLigne) {
            if (!confirm('Êtes-vous sûr de vouloir supprimer cette ligne?')) {
                return;
            }

            try {
                const response = await fetch(`/factures/${factureId}/lignes/${idLigne}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                if (response.ok) {
                    // Recharge la page pour afficher les changements
                    window.location.reload();
                } else {
                    const errorData = await response.json();
                    alert('Erreur: ' + (errorData.error || 'Une erreur est survenue'));
                }
            } catch (error) {
                console.error('Erreur lors de la suppression:', error);
                alert('Erreur lors de la suppression de la ligne');
            }
        }
    </script>
</body>
</html>
