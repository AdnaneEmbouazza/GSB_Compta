<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="/dashboard"><img src="/img/gsb-logo.webp" alt="Logo GSB" class="logo-nav"></a>
            </div>
            <div class="nav-links">
                <a href="/articles">Articles</a>
                <a href="/contacts">Contacts</a>
                <a href="/factures">Factures</a>
                <a href="/devis">Devis</a>
                <a href="/logout">Déconnexion</a>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <h1><%= title %></h1>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger">
                <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg> <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/factures" class="form">
            <div class="form-row">
                <div class="form-group">
                    <label for="numero_facture">Numéro de facture *</label>
                    <input type="text" id="numero_facture" name="numero_facture" value="<%= facture ? facture.numero_facture : '' %>" required>
                </div>

                <div class="form-group">
                    <label for="id_contact">Contact *</label>
                    <select id="id_contact" name="id_contact" required>
                        <option value="">Sélectionner...</option>
                        <% contacts.forEach(contact => { %>
                            <option value="<%= contact.id_contact %>" <%= facture && facture.id_contact === contact.id_contact ? 'selected' : '' %>>
                                <%= contact.nom_contact %>
                            </option>
                        <% }); %>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="date_facture">Date de facture *</label>
                    <input type="date" id="date_facture" name="date_facture" value="<%= facture ? facture.date_facture : new Date().toISOString().split('T')[0] %>" required>
                </div>

                <div class="form-group">
                    <label for="date_echeance">Échéance</label>
                    <input type="date" id="date_echeance" name="date_echeance" value="<%= facture ? (facture.date_echeance || '') : '' %>">
                </div>

                <div class="form-group">
                    <label for="etat_facture">État</label>
                    <select id="etat_facture" name="etat_facture">
                        <option value="brouillon" <%= facture && facture.etat_facture === 'brouillon' ? 'selected' : 'selected' %>>Brouillon</option>
                        <option value="envoyée" <%= facture && facture.etat_facture === 'envoyée' ? 'selected' : '' %>>Envoyée</option>
                        <option value="payée" <%= facture && facture.etat_facture === 'payée' ? 'selected' : '' %>>Payée</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="notes">Notes</label>
                <textarea id="notes" name="notes"><%= facture ? (facture.notes || '') : '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Créer la facture</button>
                <a href="/factures" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>

    <footer class="footer">
        <p>&copy; 2026 - Gestion Comptabilité Simple</p>
    </footer>
</body>
</html>
